# ========== Polymarket / Polygon ==========
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_PRIVATE_KEY=
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137

# ========== LLM ==========
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-7

# ========== News ==========
TAVILY_API_KEY=

# ========== Runtime ==========
RUN_MODE=dry_run            # dry_run | live
LOG_LEVEL=INFO
BANKROLL_USDC=500
MAX_POSITION_FRACTION=0.05
SQLITE_PATH=data/traces.db

# ========== Scheduler ==========
MAIN_LOOP_INTERVAL_SECONDS=600
MONITOR_LOOP_INTERVAL_SECONDS=30

# ========== Risk Circuit Breaker ==========
MAX_DAILY_LOSS_PCT=0.05              # stop for the day if PnL drops below -5% bankroll
MAX_TOTAL_EXPOSURE_PCT=0.50          # cumulative open position size cap
MAX_CONCURRENT_POSITIONS=10
MAX_CONSECUTIVE_LOSSES=5
CONSECUTIVE_LOSS_COOLDOWN_SECONDS=3600

# ========== Telegram alerts (optional) ==========
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
